{
  "name": "seps",
  "version": "0.1.0",
  "description": "Format separator/header comment markers so labels are centered and lines are a fixed width.",
  "type": "module",
  "bin": {
    "seps": "bin/cli.js"
  },
  "main": "src/insert-separators.js",
  "exports": {
    ".": "./src/insert-separators.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "cli",
    "formatter",
    "comments",
    "separators",
    "headers"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  }
}
