{
  "name": "seps",
  "version": "0.1.0",
  "description": "Format separator/header comment markers so labels are centered and each line fills up to a character limit.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanpmaxwell/seps.git"
  },
  "homepage": "https://github.com/seanpmaxwell/seps#readme",
  "bugs": "https://github.com/seanpmaxwell/seps/issues",
  "author": "Sean Maxwell",
  "bin": {
    "seps": "bin/cli.js"
  },
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "bin",
    "lib",
    "README.md"
  ],
  "scripts": {
    "start": "npm run build && node bin/cli.js",
    "build": "node scripts/build.js",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "readme:swap": "node scripts/readme.js swap",
    "readme:restore": "node scripts/readme.js restore",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run format:check && npm test && npm run readme:swap",
    "postpublish": "npm run readme:restore"
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "cli",
    "formatter",
    "comments",
    "separators",
    "separator",
    "headers",
    "header",
    "comment-headers",
    "code-comments",
    "region",
    "section",
    "banner",
    "divider",
    "code-formatting",
    "source-code"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  }
}
