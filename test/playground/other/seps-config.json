    "Extensions": ["java"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Css": {
    "Extensions": ["css", "scss"],
    "Comment": ["/* ", " */"],
    "Bookends": ["/* ", " */"]
  },
  "C": {
    "Extensions": ["c", "h"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Cpp": {
    "Extensions": ["cpp", "cc", "cxx", "hpp", "hh", "hxx"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Go": {
    "Extensions": ["go"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Rust": {
    "Extensions": ["rs"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Php": {
    "Extensions": ["php"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Ruby": {
    "Extensions": ["rb"],
    "Comment": ["# ", ""],
    "Bookends": ["# ", " #"]
  },
  "Sql": {
