{
  "All": {
    "CharacterLimit": 119,
    "FillerCharacter": "="
  },
  "JavaScript": {
    "CharacterLimit": 79,
    "Extensions": ["ts", "tsx", "js", "jsx", "mjs", "cjs"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Java": {
    "Extensions": ["java"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Css": {
    "Extensions": ["css", "scss"],
    "Comment": ["/* ", " */"],
    "Bookends": ["/* ", " */"]
  },
  "Python": {
    "Extensions": ["py"],
    "Comment": ["# ", ""],
    "Bookends": ["# ", " #"]
  },
  "Ruby": {
    "Extensions": ["rb"],
    "FillerCharacter": "*",
    "Comment": ["# ", ""],
    "Bookends": ["# ", " #"]
  },
  "Sql": {
    "Extensions": ["sql"],
    "DisableCapitalization": true,
    "Comment": ["-- ", ""],
    "Bookends": ["-- ", " --"]
  }
}
