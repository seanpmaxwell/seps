{
  "All": {
    "CharacterLimit": 120,
    "FillerCharacter": "="
  },
  "Js": {
    "Extensions": ["ts", "tsx", "js", "jsx", "mjs", "cjs"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Java": {
    "Extensions": ["java"],
    "Comment": ["// ", ""],
    "Bookends": ["// ", " //"]
  },
  "Css": {
    "Extensions": ["css", "scss"],
    "Comment": ["/* ", " */"],
    "Bookends": ["/* ", " */"]
  }
}
